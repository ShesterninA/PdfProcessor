{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "StorageSettings": {
    "UploadPdfPath": "/app/uploads",
    "MaxFileSizeMb": 10
  },
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Port=5432;Database=pdfprocessor;Username=postgres;Password=postgres"
  },
  "RabbitMQ": {
    "Host": "rabbitmq",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "QueueName": "pdf-processing"
  },
  "Outbox": {
    "PollingIntervalSeconds": 5
  }
}
